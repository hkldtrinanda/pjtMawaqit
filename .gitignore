*.pdb.meta
*.mdb.meta

# ----- OS generated files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----- JetBrains Rider -----
.idea/
*.sln.iml

